---
import ToolPage from '../../layouts/ToolPage.astro';
---

<ToolPage
  title="QuestionBank — HioTEC"
  description="DSE 練習題庫即將推出，提供全科歷屆試題、智能練習追蹤。"
  toolName="QuestionBank"
  toolTagline="DSE 練習題庫"
>
  <div class="coming-soon-page">
    <div class="container">
      <div class="coming-soon-card">
        <div class="cs-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
            <rect x="4" y="2" width="16" height="20" rx="2"/>
            <path d="M8 10 L16 10"/>
            <path d="M8 14 L13 14"/>
            <path d="M15 17 L17 19 L21 15"/>
          </svg>
        </div>
        <div class="cs-badge">
          <span class="badge badge-coming-soon">即將推出</span>
        </div>
        <h2 class="cs-title">正在開發中</h2>
        <p class="cs-desc">
          QuestionBank 是一套完整的 DSE 練習題庫，讓你系統性地備考每一科。
        </p>

        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>全科 DSE 歷屆試題收錄</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>智能錯題追蹤與複習提醒</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>詳細題解與評分準則</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>模擬考試計時模式</span>
          </div>
        </div>

        <a href="/" class="btn btn-ghost back-btn">返回首頁</a>
      </div>
    </div>
  </div>
</ToolPage>

<style>
  .coming-soon-page {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .coming-soon-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-md);
    padding: var(--space-2xl);
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .cs-icon {
    width: 64px;
    height: 64px;
    background: var(--color-accent-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .cs-title {
    font-size: var(--text-h3);
    font-weight: 900;
  }

  .cs-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 400px;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    width: 100%;
    margin-top: var(--space-xs);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-success);
  }

  .back-btn {
    margin-top: var(--space-sm);
  }
</style>
