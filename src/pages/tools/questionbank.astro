---
import ToolPage from '../../layouts/ToolPage.astro';
---

<ToolPage
  title="QuestionBank — HioTEC"
  description="DSE 數學練習題庫，提供全科歷屆試題、智能練習追蹤。"
  toolName="QuestionBank"
  toolTagline="DSE 數學練習題庫"
>
  <div class="qb-page">
    <div class="container">
      <div class="qb-card">
        <div class="qb-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
            <rect x="4" y="2" width="16" height="20" rx="2"/>
            <path d="M8 10 L16 10"/>
            <path d="M8 14 L13 14"/>
            <path d="M15 17 L17 19 L21 15"/>
          </svg>
        </div>
        <h2 class="qb-title">DSE 數學題庫</h2>
        <p class="qb-desc">
          涵蓋 2012–2025 歷屆試題，支持智能組卷、錯題追蹤、AI 輔助解題。
        </p>

        <div class="feature-list">
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>2,800+ 題目，覆蓋 Paper 1 & Paper 2</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>按主題、難度、年份篩選</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>詳細題解與評分準則</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span>智能組卷與模擬考試</span>
          </div>
        </div>

        <div class="qb-actions">
          <a href="https://math.hio.zone" target="_blank" rel="noopener" class="btn btn-accent">
            進入題庫
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
              <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a href="/" class="btn btn-ghost">返回首頁</a>
        </div>
      </div>
    </div>
  </div>
</ToolPage>

<style>
  .qb-page {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .qb-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-md);
    padding: var(--space-2xl);
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .qb-icon {
    width: 64px;
    height: 64px;
    background: var(--color-accent-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .qb-title {
    font-size: var(--text-h3);
    font-weight: 900;
  }

  .qb-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 400px;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    width: 100%;
    margin-top: var(--space-xs);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-success);
  }

  .qb-actions {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

</style>
