---
import Base from '../layouts/Base.astro';
import SubjectCard from '../components/SubjectCard.astro';
import FeatureBlock from '../components/FeatureBlock.astro';
import { subjects } from '../data/subjects';

const features = [
  {
    title: '一鍵導入',
    description: '上傳 PDF，AI 自動提取題目、答案、評分準則。支持中英雙語，幾分鐘內完成整份試卷的數碼化。',
    mockupHint: '截圖需求：PDF 上傳 → 進度條 → 提取出的題目卡片，展示 3 步流程',
  },
  {
    title: '智能組卷',
    description: '按主題、難度、年份篩選，一鍵生成模擬考卷。支持 Paper 1 長題目和 Paper 2 選擇題格式。',
    mockupHint: '截圖需求：篩選面板 + 生成的 Paper 1 / Paper 2 考卷預覽',
  },
  {
    title: '社區題庫',
    description: '分享你出的好題到公共題庫，使用人數多的題目可以獲得點數。除了我們出的公共題庫之外，其餘題目來自社區分享。',
    mockupHint: '截圖需求：題目卡片 + 分享按鈕 + 點數 / 熱度指標',
  },
  {
    title: '練習追蹤',
    description: '錯題自動歸類，弱點主題一目了然。個性化推薦練習，幫學生精準補強。',
    mockupHint: '截圖需求：學生 Dashboard — 錯題熱力圖 + 弱項雷達圖',
  },
];
---

<Base
  title="HioTEC — DSE 新一代學習基建"
  description="AI 驅動的 DSE 學習平台。從數學題庫到跨學科個性化學習，為香港學生而建。"
>
  <!-- S1: Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-inner">
      <span class="hero-badge">
        <span class="badge badge-live">Beta</span>
        <span class="hero-badge-text">免費開放使用</span>
      </span>
      <h1 class="hero-title" id="hero-heading">DSE 新一代學習基建</h1>
      <p class="hero-subtitle serif">AI 驅動，教師打造，為香港學生而生。</p>
      <p class="hero-desc">
        從數學題庫開始，構建覆蓋全科的個性化學習系統。每一個功能都來自真實課堂需求。
      </p>
      <div class="hero-cta">
        <a href="https://math.hiotec.com" class="btn btn-accent" target="_blank" rel="noopener">開始使用</a>
        <a href="#product" class="btn btn-ghost">了解更多</a>
      </div>
    </div>
  </section>

  <!-- S2: Product Showcase -->
  <section class="product-section" id="product" aria-labelledby="product-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-label mono">FLAGSHIP PRODUCT</p>
        <h2 class="section-title" id="product-heading">Math Question Bank</h2>
        <p class="section-subtitle">涵蓋 1,900+ 題目 · 59 個考點 · 2012–2025 歷屆試題</p>
      </div>

      <div class="features-list">
        {features.map((f, i) => (
          <FeatureBlock
            title={f.title}
            description={f.description}
            mockupHint={f.mockupHint}
            index={i}
          />
        ))}
      </div>

      <div class="product-cta">
        <a href="https://math.hiotec.com" class="btn btn-accent" target="_blank" rel="noopener">
          進入題庫
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- S3: Roadmap -->
  <section class="roadmap-section" id="roadmap" aria-labelledby="roadmap-heading">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title" id="roadmap-heading">Math 只是開始</h2>
        <p class="section-subtitle">一個平台，全科覆蓋。每個學科都有專門設計的題庫、練習和追蹤系統。</p>
      </div>

      <div class="subjects-grid">
        {subjects.map(s => (
          <SubjectCard
            name={s.name}
            nameCn={s.nameCn}
            description={s.description}
            status={s.status}
            eta={s.eta}
            href={s.href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- S4: Why HioTEC -->
  <section class="why-section" id="why" aria-labelledby="why-heading">
    <div class="container">
      <h2 class="section-title" id="why-heading">為什麼選 HioTEC</h2>

      <div class="pillars">
        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="pillar-title">AI 驅動</h3>
          <p class="pillar-desc">從 PDF 提取到智能組卷，AI 處理繁瑣工作，你專注教學。</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="pillar-title">教師視角</h3>
          <p class="pillar-desc">由 DSE 教師獨立開發。每個功能都來自真實課堂需求，不是產品經理的想像。</p>
        </div>

        <div class="pillar">
          <div class="pillar-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
          </div>
          <h3 class="pillar-title">DSE 專精</h3>
          <p class="pillar-desc">不是通用教育平台。專為香港 DSE 考試設計，本地化到每一個考點。</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* --- S1: Hero --- */
  .hero {
    padding: calc(80px + var(--space-3xl)) 0 var(--space-3xl);
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-badge-text {
    font-size: var(--text-body-sm);
    color: var(--color-text-tertiary);
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-h1);
    letter-spacing: -2px;
    color: var(--color-text-primary);
    line-height: 1.05;
    margin-top: var(--space-xs);
  }

  .hero-subtitle {
    font-size: clamp(18px, 2.5vw, 24px);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.4;
  }

  .hero-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* --- Section shared --- */
  .section-header {
    margin-bottom: var(--space-2xl);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .section-title {
    font-size: var(--text-h2);
    font-weight: 900;
    margin-bottom: var(--space-xs);
  }

  .section-subtitle {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 540px;
    line-height: 1.6;
  }

  /* --- S2: Product --- */
  .product-section {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .features-list {
    display: flex;
    flex-direction: column;
  }

  .product-cta {
    margin-top: var(--space-2xl);
  }

  /* --- S3: Roadmap --- */
  .roadmap-section {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .subjects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: var(--space-md);
  }

  /* Sibling dimming */
  .subjects-grid:hover :global(.subject-card) {
    background-color: transparent;
  }

  .subjects-grid:hover :global(.subject-card:hover) {
    background-color: var(--color-surface);
  }

  .subjects-grid:hover :global(.subject-card--planned:hover) {
    background-color: transparent;
  }

  /* --- S4: Why --- */
  .why-section {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .why-section .section-title {
    margin-bottom: var(--space-2xl);
  }

  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
  }

  .pillar {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .pillar-icon {
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .pillar-title {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .pillar-desc {
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 768px) {
    .pillars {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
