---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools } from '../data/tools';
---

<Base
  title="HioTEC — 為 DSE 學生而建"
  description="HioTEC 提供為香港 DSE 學生設計的學習工具，包括考場計時器、數學題庫等。"
>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container hero-inner">
      <div class="hero-badge">
        <span class="badge badge-live">Beta</span>
        <span class="hero-badge-text">免費開放使用</span>
      </div>
      <h1 class="hero-title" id="hero-heading">HioTEC</h1>
      <p class="hero-tagline">為 DSE 而生的學習工具</p>
      <p class="hero-desc">
        一套專為香港 DSE 學生打造的實用工具集合，幫你更有效率地備考。
      </p>
      <div class="hero-cta">
        <a href="/tools/dse-timer" class="btn btn-accent">試用 DSE Timer</a>
        <a href="/#tools" class="btn btn-ghost">瀏覽所有工具</a>
      </div>
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="tools-section" id="tools" aria-labelledby="tools-heading">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title" id="tools-heading">工具集合</h2>
        <p class="section-desc">持續增加中——每一個都認真做好。</p>
      </div>

      <div class="tools-grid">
        {tools.map(tool => (
          <ToolCard
            name={tool.name}
            tagline={tool.tagline}
            href={tool.href}
            status={tool.status}
            icon={tool.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about-section" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-card">
        <h2 class="about-title" id="about-heading">關於 HioTEC</h2>
        <p class="about-text">
          HioTEC 由 Hio——一位香港 DSE 教師——獨立開發。從日常教學中發現學生真正需要的工具，然後認真做好。簡潔、可靠、無廣告。
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  /* --- Hero --- */
  .hero {
    padding: calc(80px + var(--space-3xl)) 0 var(--space-3xl);
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-badge-text {
    font-size: var(--text-body-sm);
    color: var(--color-text-tertiary);
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(56px, 10vw, var(--text-h1));
    letter-spacing: -2px;
    color: var(--color-text-primary);
    line-height: 1;
    margin-top: var(--space-xs);
  }

  .hero-tagline {
    font-size: clamp(22px, 3vw, 28px);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.4;
  }

  .hero-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* --- Tools Section --- */
  .tools-section {
    padding: var(--space-3xl) 0;
  }

  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-title {
    font-size: var(--text-h2);
    font-weight: 900;
    margin-bottom: var(--space-xs);
  }

  .section-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 600px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .tools-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Sibling dimming on tool cards */
  .tools-grid:hover :global(.tool-card) {
    opacity: 0.6;
  }

  .tools-grid:hover :global(.tool-card:hover) {
    opacity: 1;
  }

  :global(.tool-card) {
    transition: transform var(--duration-short) var(--ease-enter),
                box-shadow var(--duration-short) var(--ease-enter),
                border-color var(--duration-short) var(--ease-move),
                opacity 300ms var(--ease-move);
  }

  /* --- About Section --- */
  .about-section {
    padding: var(--space-3xl) 0;
  }

  .about-card {
    background: var(--color-accent-light);
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    max-width: 640px;
  }

  .about-title {
    font-size: var(--text-h3);
    margin-bottom: var(--space-md);
  }

  .about-text {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.8;
  }
</style>
