---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  toolName: string;
  toolTagline?: string;
  noFooter?: boolean;
}

const { title, description, toolName, toolTagline, noFooter = false } = Astro.props;
---

<Base title={title} description={description} noFooter={noFooter}>
  <div class="tool-hero">
    <div class="container tool-hero-inner">
      <a href="/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd"/>
        </svg>
        返回首頁
      </a>
      <h1 class="tool-name">{toolName}</h1>
      {toolTagline && <p class="tool-tagline serif">{toolTagline}</p>}
    </div>
  </div>

  <slot />
</Base>

<style>
  .tool-hero {
    padding: calc(80px + var(--space-xl)) 0 var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
  }

  .tool-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-short) var(--ease-move);
    margin-bottom: var(--space-sm);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .tool-name {
    font-size: var(--text-h2);
    font-weight: 900;
  }

  .tool-tagline {
    font-size: var(--text-lead);
    color: var(--color-text-secondary);
  }
</style>
