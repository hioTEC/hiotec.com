---
import type { SubjectStatus } from '../data/subjects';

interface Props {
  name: string;
  nameCn: string;
  description: string;
  status: SubjectStatus;
  eta?: string;
  href?: string;
}

const { name, nameCn, description, status, eta, href } = Astro.props;

const badgeMap: Record<SubjectStatus, { label: string; class: string }> = {
  live: { label: '上線', class: 'badge-live' },
  soon: { label: eta ?? '即將', class: 'badge-soon' },
  dev: { label: eta ?? '開發中', class: 'badge-dev' },
  planned: { label: '規劃中', class: 'badge-planned' },
};

const badge = badgeMap[status];
const Tag = href ? 'a' : 'div';
---

<Tag
  class:list={['subject-card', { 'subject-card--planned': status === 'planned', 'subject-card--linked': !!href }]}
  href={href ?? undefined}
  target={href ? '_blank' : undefined}
  rel={href ? 'noopener noreferrer' : undefined}
>
  <div class="subject-card-top">
    <span class={`subject-badge ${badge.class}`}>{badge.label}</span>
  </div>
  <h3 class="subject-name">{nameCn}</h3>
  <p class="subject-name-en">{name}</p>
  <p class="subject-desc">{description}</p>
  {href && (
    <div class="subject-arrow" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
        <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
      </svg>
    </div>
  )}
</Tag>

<style>
  .subject-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: clamp(24px, 3vw, 32px);
    border: 1px solid var(--color-border-light);
    border-radius: clamp(12px, 2vw, 20px);
    background: var(--color-surface);
    min-height: 180px;
    position: relative;
    text-decoration: none;
    transition: box-shadow 0.5s ease, background-color 0.5s ease;
  }

  .subject-card--linked:hover {
    box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.04);
  }

  .subject-card--planned {
    border-style: dashed;
    background: transparent;
  }

  .subject-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .subject-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .badge-live {
    background: color-mix(in srgb, var(--color-success) 12%, transparent);
    color: var(--color-success);
  }

  .badge-soon {
    background: color-mix(in srgb, var(--color-warning) 12%, transparent);
    color: var(--color-warning);
  }

  .badge-dev {
    background: color-mix(in srgb, var(--color-blue) 10%, transparent);
    color: var(--color-blue);
  }

  .badge-planned {
    background: transparent;
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border);
  }

  .subject-name {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .subject-name-en {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin: 0;
    line-height: 1.3;
  }

  .subject-desc {
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .subject-arrow {
    color: var(--color-text-tertiary);
    transition: transform var(--duration-short) var(--ease-enter),
                color var(--duration-short) var(--ease-move);
    align-self: flex-end;
  }

  .subject-card--linked:hover .subject-arrow {
    transform: translate(2px, -2px);
    color: var(--color-accent);
  }
</style>
