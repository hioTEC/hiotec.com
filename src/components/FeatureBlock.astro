---
interface Props {
  title: string;
  description: string;
  screenshot: string;
  screenshotAlt: string;
  index: number;
}

const { title, description, screenshot, screenshotAlt, index } = Astro.props;
---

<div class="feature-block" data-index={index}>
  <div class="feature-text">
    <div class="feature-number mono">{String(index + 1).padStart(2, '0')}</div>
    <h3 class="feature-title">{title}</h3>
    <p class="feature-desc">{description}</p>
  </div>
  <div class="feature-mockup">
    <img
      src={screenshot}
      alt={screenshotAlt}
      class="mockup-img"
      loading="lazy"
      decoding="async"
    />
  </div>
</div>

<style>
  .feature-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .feature-block:first-child {
    border-top: none;
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .feature-number {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .feature-title {
    font-family: var(--font-body);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .feature-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
    max-width: 420px;
  }

  .feature-mockup {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mockup-img {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  @media (max-width: 768px) {
    .feature-block {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .feature-mockup {
      order: -1;
    }
  }
</style>
